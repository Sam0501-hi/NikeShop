@model IEnumerable<NikeShop.Models.Category>
@{
    ViewData["Title"] = "Quản lý Danh mục";
    Layout = "_AdminLayout";
}

<div class="container mt-4">
    <h1>Danh mục</h1>
    <a asp-controller="Admin" asp-action="CreateCategory" class="btn btn-primary mb-3">Thêm danh mục</a>

    <table class="table">
        <thead>
            <tr>
                <th>Tên</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.CategoryName</td>
                    <td>
                        <a asp-controller="Admin" asp-action="EditCategory" asp-route-id="@item.CategoryId" class="btn btn-sm btn-warning">Sửa</a>
                        <form asp-controller="Admin" asp-action="DeleteCategory" asp-route-id="@item.CategoryId" method="post" style="display:inline-block;" onsubmit="return confirm('Bạn có chắc muốn xóa?');">
                            <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
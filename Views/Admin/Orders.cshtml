@model IEnumerable<NikeShop.Models.ViewModels.AdminOrderViewModel>
@{
    Layout = "_AdminLayout";
}
<div class="container mt-5">
    <h2 class="text-uppercase fw-bold mb-4">Quản lý Đơn hàng</h2>
    <table class="table table-hover border">
        <thead class="table-dark">
            <tr>
                <th>Mã đơn</th>
                <th>Khách hàng</th>
                <th>Ngày đặt</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>#@item.OrderId</td>
                    <td>@item.CustomerEmail</td>
                    <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="fw-bold">@item.TotalPrice.ToString("N0") đ</td>
                    <td><span class="badge bg-secondary">@item.Status</span></td>
                    <td>
                        <a asp-action="OrderDetails" asp-route-orderId="@item.OrderId" class="btn btn-sm btn-outline-dark">Chi tiết</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
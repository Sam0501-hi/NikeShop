@model NikeShop.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
}

<h1 class="display-4">Bảng điều khiển</h1>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="p-3 border">
            <h6>Đơn hàng hôm nay</h6>
            <h2>@Model.TotalOrdersToday</h2>
            <a href="@Url.Action("Orders", "Admin")">Xem chi tiết →</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="p-3 border">
            <h6>Doanh thu tháng</h6>
            <h2>@Model.TotalRevenueThisMonth.ToString("N0") đ</h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="p-3 border">
            <h6>Sản phẩm sắp hết hàng</h6>
            <h2>@Model.LowStockProductsCount</h2>
            <a href="@Url.Action("StockManagement", "Admin")" class="text-danger">Cần bổ sung kho →</a>
        </div>
    </div>
</div>
@model NikeShop.Models.Order
@{
    Layout = "_AdminLayout";
}
<div class="container mt-5">
    <h2 class="fw-bold mb-4">Chi tiết đơn hàng #@Model.OrderId</h2>
    
    <div class="row">
        <div class="col-md-6">
            <div class="card p-3 border-0 shadow-sm">
                <p><strong>Khách hàng:</strong> @Model.User?.Email</p>
                <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>Địa chỉ:</strong> @Model.ShippingAddress</p>
                <p><strong>Số ĐT:</strong> @Model.PhoneNumber</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card p-3 border-0 shadow-sm">
                <h5 class="fw-bold">Cập nhật trạng thái</h5>
                <form asp-action="UpdateOrderStatus" method="post">
                    <input type="hidden" name="orderId" value="@Model.OrderId" />
                    <select name="status" class="form-select mb-2">
                        <option value="Pending" selected="@(Model.Status == "Pending")">Chờ xử lý</option>
                        <option value="Confirmed" selected="@(Model.Status == "Confirmed")">Đã xác nhận</option>
                        <option value="Shipped" selected="@(Model.Status == "Shipped")">Đang giao</option>
                        <option value="Delivered" selected="@(Model.Status == "Delivered")">Đã giao</option>
                    </select>
                    <button type="submit" class="btn btn-dark w-100">Cập nhật</button>
                </form>
            </div>
        </div>
    </div>

    <table class="table mt-4">
        <thead>
            <tr>
                <th>Sản phẩm</th>
                <th>Size</th>
                <th>Số lượng</th>
                <th>Đơn giá</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.OrderDetails)
            {
                <tr>
                    <td>@item.Product?.ProductName</td>
                    <td>@item.Size</td>
                    <td>@item.Quantity</td>
                    <td>@item.Price.ToString("N0") đ</td>
                </tr>
            }
        </tbody>
    </table>
</div>
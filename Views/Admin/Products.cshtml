@model IEnumerable<NikeShop.Models.Product>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Danh sách sản phẩm";
}

<div class="container mt-4">
    <h1>Danh sách sản phẩm</h1>

    <div class="mb-3">
        <a asp-controller="Admin" asp-action="CreateProduct" class="btn btn-primary">Thêm sản phẩm</a>
    </div>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Ảnh</th>
                <th>Tên</th>
                <th>Giá</th>
                <th>Danh mục</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @{ var img = item.Images != null && item.Images.Any() ? item.Images.First().ImagePath : item.Image; }
                        <img src="@Url.Content(img.StartsWith("/") ? img : "~/" + img.TrimStart('/'))" alt="thumb" style="width:60px;height:60px;object-fit:cover;" />
                    </td>
                    <td>@item.ProductName</td>
                    <td>@item.Price.ToString("N0")đ</td>
                    <td>@item.Category?.CategoryName</td>
                    <td>
                        <a asp-controller="Admin" asp-action="EditProduct" asp-route-id="@item.ProductId" class="btn btn-sm btn-warning">Sửa</a>
                        <form asp-controller="Admin" asp-action="DeleteProduct" asp-route-id="@item.ProductId" method="post" style="display:inline-block;" onsubmit="return confirm('Bạn có chắc muốn xóa?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                        </form>
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-sm btn-info">Xem</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
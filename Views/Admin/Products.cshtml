@model IEnumerable<NikeShop.Models.Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
    Layout = "_AdminLayout";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Danh sách sản phẩm</h2>
        <a asp-action="CreateProduct" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Thêm sản phẩm mới</a>
    </div>

    <table class="table table-hover align-middle border">
        <thead class="table-dark">
            <tr>
                <th>Ảnh</th>
                <th>Tên sản phẩm</th>
                <th>Danh mục</th>
                <th>Giá</th>
                <th>Biến thể (Màu/Size)</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><img src="@item.Image" width="60" class="rounded border" alt="img" /></td>
                    <td class="fw-bold">@item.ProductName</td>
                    <td><span class="badge bg-info">@item.Category?.CategoryName</span></td>
                    <td class="text-danger fw-bold">@item.Price.ToString("N0") VNĐ</td>
                    <td>
                        @if (item.Variants != null && item.Variants.Any())
                        {
                            foreach (var v in item.Variants)
                            {
                                <span class="badge bg-secondary">@v.Color - Size @v.Size (@v.StockQuantity)</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">Chưa có biến thể</span>
                        }
                    </td>
                  <td>
    <a asp-action="EditProduct" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-warning me-2">
        Sửa
    </a>
    
    <form asp-action="DeleteProduct" asp-route-productId="@item.ProductId" method="post" class="d-inline" onsubmit="return confirm('Bạn chắc chắn muốn xóa?');">
        <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
    </form>
</td>
                </tr>
            }
        </tbody>
    </table>
</div>
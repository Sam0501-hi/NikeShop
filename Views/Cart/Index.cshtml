@model IEnumerable<NikeShop.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng của bạn";
}

<div class="card card-custom p-4 mt-4">
    <h2 class="fw-bold text-custom mb-4">Giỏ hàng của bạn</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center" style="border-radius: 10px;">
            Giỏ hàng của bạn đang trống. <a asp-controller="Products" asp-action="Index" class="fw-bold text-custom">Tiếp tục mua sắm</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle text-center">
                <thead class="table-light">
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Tên</th>
                        <th>Size</th>
                        <th>Màu</th>
                        <th>Đơn giá</th>
                        <th>Số lượng</th>
                        <th>Thành tiền</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                             <img src="@(item.Image?.StartsWith("http") == true ? item.Image : Url.Content("~" + item.Image))"
     class="img-fluid" alt="@item.ProductName"
     onerror="this.src='https://via.placeholder.com/500x500'" style="border-radius: 4px;">
                            </td>
                            <td class="fw-bold">@item.ProductName</td>
                            <td>@item.Size</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Color))
                                {
                                    <div class="d-flex align-items-center justify-content-center">
                                        <span class="rounded-circle border me-2" style="width:16px;height:16px;display:inline-block;background-color:@item.Color;"></span>
                                        <span class="text-uppercase">@item.Color</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">Không có màu</span>
                                }
                            </td>
                            <td class="text-danger fw-bold">@item.Price.ToString("N0") đ</td>
                            <td>@item.Quantity</td>
                            <td class="text-danger fw-bold">@item.Total.ToString("N0") đ</td>
                            <td>
                                <a asp-action="Remove" asp-route-id="@item.ProductId" asp-route-size="@item.Size" class="btn btn-sm btn-outline-danger" style="border-radius: 8px;">Xóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4 border-top pt-3">
            <h4 class="fw-bold">Tổng cộng: <span class="text-danger">@Model.Sum(x => x.Total).ToString("N0") đ</span></h4>
            <div>
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary me-2" style="border-radius: 25px;">Tiếp tục mua hàng</a>
                <a asp-controller="Checkout" asp-action="Index" class="btn btn-custom">Thanh toán ngay</a>
            </div>
        </div>
    }
</div>
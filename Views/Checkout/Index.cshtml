@model IEnumerable<NikeShop.Models.CartItem>

@{
    ViewData["Title"] = "Thanh toán";
}

<div class="row mt-4">
    <div class="col-md-7 mb-4">
        <div class="card card-custom p-4 border-0">
            <h4 class="fw-bold mb-4 text-uppercase">Thông tin giao hàng</h4>
            
            <form asp-action="ProcessOrder" method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold">Số điện thoại người nhận</label>
                    <input type="text" name="phoneNumber" class="form-control" placeholder="Ví dụ: 0912345678" required style="border-radius: 4px;" />
                </div>
                
                <div class="mb-4">
                    <label class="form-label fw-bold">Địa chỉ giao hàng chi tiết</label>
                    <textarea name="shippingAddress" class="form-control" rows="3" placeholder="Số nhà, Tên đường, Phường/Xã, Quận/Huyện, Tỉnh/Thành phố" required style="border-radius: 4px;"></textarea>
                </div>

                <button type="submit" class="btn btn-custom w-100 py-3 fs-5">Xác nhận đặt hàng</button>
            </form>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card card-custom p-4 border-0 bg-light">
            <h5 class="fw-bold mb-4 text-uppercase border-bottom pb-2">Tóm tắt đơn hàng</h5>
            
            @foreach (var item in Model)
            {
                <div class="d-flex justify-content-between mb-3 align-items-center">
                    <div class="d-flex align-items-center">
                        <img src="@(item.Image?.StartsWith("http") == true ? item.Image : Url.Content("~" + item.Image))" alt="@item.ProductName"
                             style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px;" 
                             onerror="this.src='https://via.placeholder.com/50'" />
                        <div class="ms-3">
                            <h6 class="mb-0 fw-bold">@item.ProductName</h6>
                            <small class="text-muted d-flex align-items-center">
                                <span class="me-2">Size: @item.Size</span>
                                <span class="me-2">SL: @item.Quantity</span>
                                <span class="d-inline-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(item.Color))
                                    {
                                        <span class="rounded-circle border me-2" style="width:14px;height:14px;background-color:@item.Color;display:inline-block;vertical-align:middle;"></span>
                                        <span>@item.Color</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Không có màu</span>
                                    }
                                </span>
                            </small>
                        </div>
                    </div>
                    <span class="fw-bold">@item.Total.ToString("N0") đ</span>
                </div>
            }
            
            <div class="border-top pt-3 mt-3 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0">Tổng cộng</h5>
                <h4 class="text-danger fw-bold mb-0">@Model.Sum(x => x.Total).ToString("N0") đ</h4>
            </div>
        </div>
    </div>
</div>
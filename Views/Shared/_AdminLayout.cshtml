<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>NikeShop Admin | @ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background: #f8f9fa; }
        .sidebar { min-height: 100vh; background: #000; color: #fff; width: 250px; }
        .sidebar a { color: #ccc; text-decoration: none; display: block; padding: 15px; border-bottom: 1px solid #333; }
        .sidebar a:hover { color: #fff; background: #222; }
        .main-content { padding: 20px; }
    </style>
</head>
<body>
    <div class="d-flex">
        <div class="sidebar">
            <h4 class="p-3 border-bottom border-secondary">NIKESHOP ADMIN</h4>
            <a asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
            <a asp-controller="Admin" asp-action="Orders">Đơn hàng</a>
            <a asp-controller="Admin" asp-action="Products">Tồn kho</a>
            <a asp-controller="Admin" asp-action="Categories">Danh mục</a>
            <a asp-controller="Account" asp-action="Logout" class="text-danger">Đăng xuất</a>
        </div>

        <div class="main-content flex-grow-1">
            @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
            @if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }
            
            @RenderBody()
        </div>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
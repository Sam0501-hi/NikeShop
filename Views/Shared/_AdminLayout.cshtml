@using Microsoft.AspNetCore.Identity
@using NikeShop.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NIKESHOP ADMIN</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
            body {
                background: #f8f9fa;
            }

            .admin-container {
                display: flex;
            }

            .admin-sidebar {
                background: #000;
                color: #fff;
                width: 220px;
                min-height: 100vh;
                padding: 15px;
            }

                .admin-sidebar h2 {
                    color: #fff;
                }

                .admin-sidebar a {
                    color: #ccc;
                    text-decoration: none;
                    display: block;
                    padding: 10px 0;
                }

                    .admin-sidebar a:hover {
                        color: #fff;
                    }

            .admin-main {
                flex-grow: 1;
                padding: 20px;
            }
    </style>
</head>
<body>
    <div class="admin-container d-flex">
        <aside class="admin-sidebar bg-dark text-white p-3" style="width:220px;min-height:100vh;">
            <h2 class="text-white">NIKESHOP ADMIN</h2>
            <ul class="nav flex-column mt-4">
                <li class="nav-item"><a class="nav-link text-white" href="@Url.Action("Dashboard", "Admin")">Dashboard</a></li>
                <li class="nav-item"><a class="nav-link text-white" href="@Url.Action("Orders", "Admin")">Đơn hàng</a></li>
                <li class="nav-item"><a class="nav-link text-white" href="@Url.Action("StockManagement", "Admin")">Tồn kho</a></li>
                <li class="nav-item"><a class="nav-link text-white" href="@Url.Action("Products", "Admin")">Sản phẩm</a></li>
                <li class="nav-item"><a class="nav-link text-white" href="@Url.Action("Categories", "Admin")">Danh mục</a></li>
                <li class="nav-item mt-3">
                    <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">← Giao diện chính</a>
                </li>
            </ul>
        </aside>

        <main class="admin-main flex-fill p-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@model IEnumerable<NikeShop.Models.Product>

@{
    ViewData["Title"] = "Cửa hàng - NIKESHOP";
    // Ép kiểu dữ liệu ViewBag truyền từ Controller sang
    var categories = ViewBag.Categories as IEnumerable<NikeShop.Models.Category>;
    var currentCategoryId = ViewBag.CurrentCategoryId as int?;
}

<div class="container mt-5">
    <div class="row">
        <!-- Sidebar Danh mục (Cột trái) -->
        <div class="col-md-3">
            <div class="card mb-4 shadow-sm rounded-0">
                <div class="card-header bg-white border-bottom">
                    <h6 class="mb-0 fw-bold py-2">Danh mục</h6>
                </div>
                <div class="list-group list-group-flush">
                    <!-- Nút Tất cả sản phẩm -->
                    <a href="@Url.Action("Index", "Products")"
                       class="list-group-item list-group-item-action border-0 @(currentCategoryId == null ? "fw-bold text-dark" : "text-muted")">
                        Tất cả sản phẩm
                    </a>

                    <!-- Render danh sách danh mục từ Database -->
                    @if (categories != null)
                    {
                        foreach (var item in categories)
                        {
                            <a href="@Url.Action("Index", "Products", new { categoryId = item.CategoryId })"
                               class="list-group-item list-group-item-action border-0 py-2 @(currentCategoryId == item.CategoryId ? "fw-bold text-dark" : "text-muted")">
                                @item.CategoryName
                            </a>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Lưới Hiển thị Sản phẩm (Cột phải) -->
        <div class="col-md-9">
            <div class="row g-4">
                @if (Model != null && Model.Any())
                {
                    foreach (var product in Model)
                    {
                        <div class="col-12 col-md-6 col-lg-4">
                            <div class="card h-100 shadow-sm border-0 product-card">
                                <!-- Hình ảnh sản phẩm -->
                                <div class="bg-light d-flex align-items-center justify-content-center p-3" style="height: 250px;">
                                    @if (!string.IsNullOrEmpty(product.Image))
                                    {
                                        <img src="@product.Image" class="img-fluid" style="max-height: 100%; object-fit: contain;" alt="@product.ProductName">
                                    }
                                    else
                                    {
                                        <img src="~/images/no-image.png" class="img-fluid" alt="No Image">
                                    }
                                </div>

                                <!-- Thông tin sản phẩm -->
                                <div class="card-body text-center d-flex flex-column justify-content-end pb-3">
                                    <h6 class="card-title fw-bold text-dark mb-2">@product.ProductName</h6>
                                    <p class="text-danger fw-bold mb-3" style="font-size: 0.95rem;">
                                        @product.Price.ToString("N0") VNĐ
                                    </p>
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductId"
                                       class="btn btn-dark w-100 rounded-1 text-uppercase fw-bold" style="font-size: 0.85rem; padding: 10px 0;">
                                        XEM CHI TIẾT
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center mt-5">
                        <h5 class="text-muted">Không tìm thấy sản phẩm nào thuộc danh mục này.</h5>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    /* Styling cho sidebar */
    .list-group-item-action {
        font-size: 0.95rem;
        transition: all 0.2s ease;
    }

        .list-group-item-action:hover {
            background-color: #f8f9fa;
            color: #000 !important;
            font-weight: 500;
        }

    /* Hiệu ứng hover cho card sản phẩm */
    .product-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1) !important;
        }
</style>